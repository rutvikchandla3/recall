{
  "name": "coding-agent-recall",
  "version": "0.1.2",
  "description": "Unified natural-language search and resume for coding agent sessions",
  "type": "module",
  "bin": {
    "recall": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "assets/recall-ui.png"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "index": "tsx src/cli.ts index",
    "search": "tsx src/cli.ts search",
    "sync": "tsx src/cli.ts sync",
    "doctor": "tsx src/cli.ts doctor",
    "config": "tsx src/cli.ts config",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rutvikchandla3/recall.git"
  },
  "bugs": {
    "url": "https://github.com/rutvikchandla3/recall/issues"
  },
  "homepage": "https://github.com/rutvikchandla3/recall#readme",
  "keywords": [
    "cli",
    "tui",
    "search",
    "agents",
    "claude",
    "codex",
    "pi"
  ],
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "node-llama-cpp": "^3.18.1",
    "react": "^18.3.1",
    "sqlite-vec": "0.1.9",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.10",
    "@types/react": "^18.3.12",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
