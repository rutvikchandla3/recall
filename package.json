{
  "name": "recall",
  "version": "0.1.0",
  "private": true,
  "description": "Unified natural-language search and resume for coding agent sessions",
  "type": "module",
  "bin": {
    "recall": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "index": "tsx src/cli.ts index",
    "search": "tsx src/cli.ts search",
    "sync": "tsx src/cli.ts sync",
    "doctor": "tsx src/cli.ts doctor",
    "config": "tsx src/cli.ts config",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.10",
    "@types/react": "^18.3.12",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
